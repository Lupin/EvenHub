#!/usr/bin/env bash
#===============================================================================
# g2-convert — macOS executable wrapper for the G2 Image Converter
#
# Auto-manages a Python venv with Pillow and runs the conversion script.
# Drop an image on this file or run from Terminal:
#   g2-convert input.jpg output.png
#   g2-convert photo.png g2-photo.png --crop --contrast 1.5
#
# Part of the EvenHub Toolbox:
#   /Users/gael/Documents/GitHub/EvenHub/toolbox/
#===============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
VENV_DIR="$HOME/.even-toolbox/venv"
PYTHON_SCRIPT="$SCRIPT_DIR/g2-convert.py"

# ── Ensure venv exists ───────────────────────────────────────────────────────
if [[ ! -f "$VENV_DIR/bin/python3" ]]; then
    echo "🔧 First run — setting up Python venv..."
    mkdir -p "$(dirname "$VENV_DIR")"
    python3 -m venv "$VENV_DIR"
    "$VENV_DIR/bin/pip" install --quiet Pillow
    echo "✓ venv ready at $VENV_DIR"
fi

# ── Run the script ───────────────────────────────────────────────────────────
exec "$VENV_DIR/bin/python3" "$PYTHON_SCRIPT" "$@"
